# --- Application Settings ---
PROJECT_NAME=Aegra
VERSION="0.1.0"
DEBUG=true

# [MANDATORY] Path to the main agent configuration file
AEGRA_CONFIG=aegra.json

# --- Database ---
# Option 1: Single connection string (standard for containers/cloud)
# If your password contains special characters (@, /, #, %, +, etc.),
# URL-encode them in DATABASE_URL (e.g. p@ss → p%40ss).
# Individual POSTGRES_* vars (Option 2) handle encoding automatically.
# DATABASE_URL=postgresql://user:password@host:5432/aegra
#
# Option 1b: Multi-host for native PostgreSQL HA (failover handled by drivers)
# DATABASE_URL=postgresql://user:password@primary:5432,standby:5432/aegra?target_session_attrs=read-write
#
# Option 2: Individual fields (used when DATABASE_URL is not set)
POSTGRES_DB=aegra
POSTGRES_HOST=localhost
POSTGRES_PASSWORD=password
POSTGRES_PORT=5432
POSTGRES_USER=user
DB_ECHO_LOG=false

# --- Connection Pools ---
# SQLAlchemy (Metadata & App)
SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20

# LangGraph (Agent Runtime)
LANGGRAPH_MIN_POOL_SIZE=5
LANGGRAPH_MAX_POOL_SIZE=20

# --- Authentication ---
AUTH_TYPE=custom  # noop, custom

# Keycloak (required when AUTH_TYPE=custom and using keycloak_auth.py)
# Option A: full issuer URL (recommended). Must match token "iss" claim exactly.
# IMPORTANT: this realm must be the same realm where your client lives.
KEYCLOAK_ISSUER=http://localhost:8080/realms/aegra
# Option B: build issuer from base URL + realm
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=my-realm
# Realm used by docker-compose default KEYCLOAK_JWKS_URL.
KEYCLOAK_REALM=aegra
# Optional override (internal docker URL; keep realm aligned with KEYCLOAK_ISSUER)
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/aegra/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=aegra-api
# For client_credentials tokens, Keycloak often sets aud="account" unless you add an
# audience mapper for your API client. Use KEYCLOAK_AUDIENCE=account as a quick fix,
# or configure Keycloak so aud includes aegra-api (recommended).
# KEYCLOAK_AUDIENCE=aegra-api

# Keycloak server bootstrap/admin settings (docker-compose)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_HOSTNAME_STRICT=true
MINIO_OIDC_CLIENT_ID=minio-console
MINIO_OIDC_CLIENT_SECRET=minio-console-local-secret
MINIO_OIDC_REDIRECT_URI=http://localhost:9001/oauth_callback

# --- Server Configuration ---
HOST=0.0.0.0
PORT=2026
# SERVER_URL takes precedence over HOST/PORT when set.
# When unset, it is derived automatically as http://{HOST}:{PORT}.
# SERVER_URL=http://localhost:2026

# --- Logging ---
LOG_LEVEL=INFO
ENV_MODE=LOCAL # DEVELOPMENT, PRODUCTION, LOCAL (PRODUCTION outputs JSON logs)
LOG_VERBOSITY=standard # standard, verbose (verbose outputs request-id)
# LOG_EXCLUDE_PATHS=/health,/ok  # Comma-separated path prefixes to skip in access logs

# --- Redis (Event Broker & Job Queue) ---
# Enable Redis for multi-instance SSE streaming and worker job dispatch.
# When enabled, runs are dispatched via a Redis job queue (BLPOP) and
# executed by concurrent worker tasks with lease-based crash recovery.
# When disabled (dev mode), runs execute as in-process asyncio tasks.
REDIS_BROKER_ENABLED=false
REDIS_URL=redis://localhost:6379/0
# REDIS_CHANNEL_PREFIX=aegra:run:
# REDIS_MAX_CONNECTIONS=250

# --- Worker Configuration ---
# Controls worker concurrency when REDIS_BROKER_ENABLED=true.
# Total capacity per instance = WORKER_COUNT * N_JOBS_PER_WORKER.
# WORKER_COUNT=3
# N_JOBS_PER_WORKER=10
# BG_JOB_TIMEOUT_SECS=3600
# BG_JOB_MAX_RETRIES=3
# STUCK_PENDING_THRESHOLD_SECONDS=120
# LEASE_DURATION_SECONDS=30
# HEARTBEAT_INTERVAL_SECONDS=10
# REAPER_INTERVAL_SECONDS=15

# --- LLM Providers ---
# Set `MODEL` to switch between providers: use `openai/<model>` for OpenAI or
# `vllm/<served-model>` for an OpenAI-compatible vLLM endpoint.
# Use `vllm/active` to follow the currently active served model automatically.
MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=sk-...
# Optional: override the default OpenAI API endpoint.
# OPENAI_BASE_URL=https://api.openai.com/v1
# Optional: OpenAI-compatible vLLM endpoint. When using `MODEL=vllm/<served-model>`,
# Aegra will send requests here while still using OPENAI_API_KEY for auth (leave
# it empty if your vLLM does not require an auth key).
# Do not set OPENAI_BASE_URL to the same vLLM URL unless you also want plain
# `openai/<model>` configs to use that same endpoint.
# VLLM_BASE_URL=http://192.168.254.104:8001/v1
# ANTHROPIC_API_KEY=...
# TOGETHER_API_KEY=...

# --- Token Limit Guardrails ---
# Hard token limit for input+output context budget.
NUM_LIMIT_TOKEN=65536
# Reserve tokens for generated output (deducted from input budget).
NUM_LIMIT_RESPONSE_RESERVE=4096
# Additional safety margin to absorb tokenizer/provider differences.
NUM_LIMIT_SAFETY_BUFFER=1024
# Keep at least this many most-recent messages before aggressive trimming.
NUM_LIMIT_MIN_RECENT_MESSAGES=6

# --- Analytic Agent Database ---
# For local testing, SQLite is the easiest option.
ANALYTIC_DB_URL=sqlite:///./analytic_test.db
ANALYTIC_DB_DIALECT=sqlite
# ANALYTIC_DB_HOST=localhost
# ANALYTIC_DB_PORT=5432
# ANALYTIC_DB_NAME=analytics
# ANALYTIC_DB_USER=readonly_user
# ANALYTIC_DB_PASSWORD=readonly_password

# --- KMS Vector OpenSearch ---
# Leave blank to disable KMS vector retrieval.
KMS_OPENSEARCH_HOST=
KMS_OPENSEARCH_PORT=9200
KMS_OPENSEARCH_USER=
KMS_OPENSEARCH_PASSWORD=
KMS_OPENSEARCH_INDEX=
KMS_OPENSEARCH_USE_SSL=true
KMS_OPENSEARCH_VERIFY_CERTS=true
KMS_OPENSEARCH_SSL_ASSERT_HOSTNAME=true
KMS_EMBEDDING_MODEL=text-embedding-3-small
KMS_SEARCH_K=4

# Optional: dedicate a separate OpenAI-compatible endpoint/key for embeddings.
# EMBEDDING_BASE_URL=http://localhost:8001/v1
# EMBEDDING_API_KEY=

# --- Prometheus Metrics ---
# Expose /metrics endpoint with HTTP request metrics in Prometheus format.
# Note: /metrics is unauthenticated by design (scrapers don't support app-level auth).
# Use network-level controls to restrict access if needed.
ENABLE_PROMETHEUS_METRICS=false

# --- Observability (OpenTelemetry) ---
# Unified config for tracing. Supports multiple targets via Fan-out.
OTEL_SERVICE_NAME=aegra-backend
# Enable targets by comma-separated list: "LANGFUSE,PHOENIX,GENERIC"
# Leave empty to disable tracing.
OTEL_TARGETS=""
# Enable debug tracing to console (stdout)
OTEL_CONSOLE_EXPORT=false

# [Target: Langfuse]
# Note: uses LANGFUSE_BASE_URL (not HOST) to match SDK standards
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-...
LANGFUSE_SECRET_KEY=sk-...

# [Target: Arize Phoenix]
# Default local endpoint shown
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_API_KEY=

# [Target: Generic OTLP]
# For Jaeger, Honeycomb, or other OTLP collectors
OTEL_EXPORTER_OTLP_ENDPOINT=
# Example headers: "Authorization=Bearer <token>,X-Custom=Value"
OTEL_EXPORTER_OTLP_HEADERS=
