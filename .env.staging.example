# --- Application Settings ---
PROJECT_NAME=Aegra
VERSION="0.1.0"
DEBUG=false
AEGRA_CONFIG=

# --- Database ---
POSTGRES_USER=user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=aegra
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_ECHO_LOG=false

# --- Connection Pools ---
SQLALCHEMY_POOL_SIZE=2
SQLALCHEMY_MAX_OVERFLOW=0
LANGGRAPH_MIN_POOL_SIZE=1
LANGGRAPH_MAX_POOL_SIZE=6

# --- Authentication ---
AUTH_TYPE=custom
KEYCLOAK_ISSUER=http://10.10.5.190:8080/realms/aegra
KEYCLOAK_REALM=aegra
KEYCLOAK_JWKS_URL=http://10.10.5.190:8080/realms/aegra/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=aegra-api
KEYCLOAK_CLIENT_SECRET=changeme

# --- Keycloak Bootstrap ---
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KEYCLOAK_HOSTNAME=10.10.5.190
KEYCLOAK_HOSTNAME_STRICT=false
KEYCLOAK_REALM_IMPORT_FILE=/home/kms/onyx_ai_secret/keycloak-realm-aegra.staging.json
KEYCLOAK_NEXTAUTH_CLIENT_ID=executive-nextauth
KEYCLOAK_NEXTAUTH_CLIENT_SECRET=changeme
KEYCLOAK_NEXTAUTH_REDIRECT_URI=http://10.10.5.190:3000/api/auth/callback/keycloak
KEYCLOAK_NEXTAUTH_WEB_ORIGIN=http://10.10.5.190:3000
MINIO_OIDC_CLIENT_ID=minio-console
MINIO_OIDC_CLIENT_SECRET=changeme
MINIO_OIDC_REDIRECT_URI=http://10.10.5.190:9001/oauth_callback
MINIO_OIDC_WEB_ORIGIN=http://10.10.5.190:9001

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8111
SERVER_URL=http://10.10.5.190:8111

# --- Logging ---
LOG_LEVEL=INFO
ENV_MODE=DEVELOPMENT
LOG_VERBOSITY=standard

# --- LLM Providers ---
MODEL=openai/gpt-4o-mini
OPENAI_API_KEY=changeme

# --- Token Limit Guardrails ---
NUM_LIMIT_TOKEN=65536
NUM_LIMIT_RESPONSE_RESERVE=4096
NUM_LIMIT_SAFETY_BUFFER=1024
NUM_LIMIT_MIN_RECENT_MESSAGES=6

# --- Analytic Agent Database ---
ANALYTIC_DB_URL=sqlite:///./analytic_test.db
ANALYTIC_DB_DIALECT=sqlite

# --- KMS Vector OpenSearch ---
KMS_OPENSEARCH_HOST=
KMS_OPENSEARCH_PORT=9200
KMS_OPENSEARCH_USER=
KMS_OPENSEARCH_PASSWORD=
KMS_OPENSEARCH_INDEX=
KMS_OPENSEARCH_USE_SSL=true
KMS_OPENSEARCH_VERIFY_CERTS=true
KMS_OPENSEARCH_SSL_ASSERT_HOSTNAME=true
KMS_EMBEDDING_MODEL=text-embedding-3-small
KMS_SEARCH_K=4

# --- Observability ---
OTEL_SERVICE_NAME=aegra-backend
OTEL_TARGETS=""
OTEL_CONSOLE_EXPORT=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=changeme
LANGFUSE_SECRET_KEY=changeme
PHOENIX_COLLECTOR_ENDPOINT=http://127.0.0.1:6006/v1/traces
PHOENIX_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
